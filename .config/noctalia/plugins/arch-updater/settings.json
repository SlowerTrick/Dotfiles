{
  "checkCmd": "(checkupdates; yay -Qua) 2>/dev/null",
  "updateCmd": "kitty -e bash -c 'echo \"Updating System...\";sudo pacman -Syu;yay -Syu; flatpak update; read -n 1 -p \"Press any key to exit...\"'",
  "flatpak": true,
  "noctalia": true,
  "toast": true,
  "desktopTip": true,
  "hideOnEmpty": false,
  "refreshTimer": true,
  "refreshInterval": 120,
  "iconName": "pacman",
  "useDistroLogo": false,
  "customIconPath": "",
  "boldText": true,
  "enableColorization": true,
  "iconColor": "primary",
  "boldVer": true,
  "tooltip": true
}
